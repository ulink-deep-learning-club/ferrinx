# Ferrinx Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# =============================================================================
# Authentication
# Secret key used to sign and verify API keys
# Generate a secure random string: openssl rand -hex 32
# =============================================================================
FERRINX_API_KEY_SECRET=your-secret-key-here

# =============================================================================
# Database
# PostgreSQL connection string
# Format: postgresql://user:password@host:port/database
# =============================================================================
FERRINX_DATABASE_URL=postgresql://user:password@localhost:5432/ferrinx

# =============================================================================
# Redis
# Redis connection string
# Format: redis://[:password@]host:port/db
# =============================================================================
FERRINX_REDIS_URL=redis://localhost:6379
